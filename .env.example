# PostgreSQL (servicio db)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=unilab
# Puerto en el host (mapeo docker-compose). Dentro del contenedor PostgreSQL sigue en 5432.
POSTGRES_PORT=5433

# Backend (servicio api)
JWT_SECRET=cambiar-este-secreto-en-produccion
API_PORT=3000
API_PUBLIC_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:4200,http://localhost:8080

# Frontend (servicio front)
FRONT_PORT=8080
