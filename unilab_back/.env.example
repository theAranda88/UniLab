# Backend local contra PostgreSQL de Docker Compose: usa POSTGRES_PORT del .env raíz (por defecto 5433).
# PostgreSQL instalado nativamente en el host suele usar 5432.
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/unilab?schema=public"
JWT_SECRET="cambiar-este-secreto-en-produccion"
PORT=3000
API_PUBLIC_URL="http://localhost:3000"
CORS_ORIGINS="http://localhost:4200,http://localhost:8080"
