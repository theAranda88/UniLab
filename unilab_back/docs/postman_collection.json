            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/usuarios",
            "description": "Lista todos los usuarios activos."
          }
        },
        {
          "name": "Listar usuarios por rol",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/usuarios?rol=Estudiante",
              "host": ["{{base_url}}"],
              "path": ["usuarios"],
              "query": [{ "key": "rol", "value": "Estudiante", "description": "Filtrar por rol" }]
            },
            "description": "Filtro opcional: Administrador, Coordinador, Profesor, Estudiante, Externo."
          }
        },
        {
          "name": "Obtener usuario por ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/usuarios/1",
            "description": "Detalle de un usuario (incluye perfil extendido)."
          }
        },
        {
          "name": "Crear usuario (profesor)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombres\": \"Nuevo\",\n  \"apellidos\": \"Profesor\",\n  \"email\": \"nuevo.profesor@unilab.edu\",\n  \"documento_identidad\": \"1088888888\",\n  \"telefono\": \"3008888888\",\n  \"rol\": \"Profesor\",\n  \"codigo_docente\": \"DOC-999\",\n  \"id_escuela\": 5\n}"
            },
            "url": "{{base_url}}/usuarios",
            "description": "Devuelve `password_temporal` para entregar al usuario."
          }
        },
        {
          "name": "Actualizar usuario",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"telefono\": \"3001111111\"\n}"
            },
            "url": "{{base_url}}/usuarios/2",
            "description": "Actualiza campos del usuario y perfil extendido."
          }
        },
        {
          "name": "Suspender / reactivar usuario",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/usuarios/2/suspender",
            "description": "Alterna el campo `activo` del usuario."
          }
        },
        {
          "name": "Eliminar usuario",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/usuarios/99",
            "description": "Soft-delete (marca `deleted_at`)."
          }
        }
      ]
    },
